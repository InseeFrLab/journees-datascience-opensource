<%
// Le HTML émis est relu comme du markdown : pas d'indentation sur les lignes
// HTML, sinon elles deviennent des blocs de code.
const labels = {
  pr: "Pull requests",
  issue: "Issues",
  review: "Revues",
  commit: "Commits"
};
const typeOrder = ["pr", "issue", "review", "commit"];

// Déduit le dépôt (owner/repo) à partir de l'url GitHub de la contribution.
function repoFromUrl(url) {
  const m = (url || "").match(/github\.com\/([^/]+\/[^/]+)/);
  return m ? m[1] : "";
}

// Affiche un groupe de contributions, regroupées par type.
function renderType(item) { %>
<li>
<span class="contrib-titre"><%= item.titre %></span>
<% if (item.auteur) { %><a class="contrib-auteur" href="https://github.com/<%= item.auteur.replace(/^@/, '') %>" target="_blank" rel="noopener">&#64;<%= item.auteur.replace(/^@/, '') %></a><% } %>
<% if (item.url) { %><a class="repo-link" href="<%= item.url %>" target="_blank" rel="noopener">→ Voir</a><% } %>
</li>
<% }
function renderGroup(group) {
  const byType = {};
  for (const item of group) {
    (byType[item.type] ||= []).push(item);
  }
  const types = Object.keys(byType).sort(
    (a, b) => typeOrder.indexOf(a) - typeOrder.indexOf(b)
  );
  for (const type of types) { %>
<h3 class="contrib-type-titre"><span class="badge badge-<%= type %>"><%= labels[type] || type %></span></h3>
<ul class="contrib-list">
<% for (const item of byType[type]) { renderType(item); } %>
</ul>
<% }
}

// Regroupe les contributions par projet ("Divers" toujours en dernier).
const byProjet = {};
for (const item of items) {
  (byProjet[item.projet] ||= []).push(item);
}
const projets = Object.keys(byProjet).sort((a, b) => {
  if (a === "Divers") return 1;
  if (b === "Divers") return -1;
  return a.localeCompare(b, "fr");
});
%>
<% for (const projet of projets) { %>
<h2 class="contrib-projet"><%= projet %></h2>
<% if (projet === "Divers") {
  // Pour « Divers », on regroupe par dépôt, trié par nom de dépôt,
  // avec le nom du dépôt en sous-titre.
  const byRepo = {};
  for (const item of byProjet[projet]) {
    (byRepo[repoFromUrl(item.url)] ||= []).push(item);
  }
  // Affiche seulement le nom du dépôt (sans l'org/profil), trié par ce nom.
  const repos = Object.keys(byRepo).sort((a, b) =>
    a.split("/").pop().localeCompare(b.split("/").pop(), "fr")
  );
  for (const repo of repos) { %>
<h3 class="contrib-repo"><%= repo.split("/").pop() %></h3>
<% renderGroup(byRepo[repo]);
  }
} else {
  renderGroup(byProjet[projet]);
} %>
<% } %>
